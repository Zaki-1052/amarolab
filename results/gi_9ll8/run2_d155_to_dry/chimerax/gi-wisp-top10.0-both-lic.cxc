graphics silhouettes false;
cartoon suppress false;
close #2-*;
~show a;
transp 60 target c;
color dim gray;
show /B:1-340 c; transp /B:1-340 60 target c; color /B:1-340 dim gray;
show /G:1-71 c; transp /G:1-71 60 target c; color /G:1-71 dim gray;
show /A:1-227 c; transp /A:1-227 0 target c;
show /R:1-262 c; transp /R:1-262 0 target c;
show /L:1-1 c; transp /L:1-1 60 target c; color /L:1-1 dim gray;
